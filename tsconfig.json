{
  "compilerOptions": {
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "noEmit": false,
    "noEmitOnError": false,
    "outDir": "./dist",
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": false,
    "strict": false,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,
    "noImplicitOverride": true,
    "types": [
      "jest",
      "bun"
    ]
  },
  "include": [
    "src/**/*",
    "scripts/**/*",
    "tests/**/*",
    "old/cf-bypass-old-buggy.ts"
  ]
}